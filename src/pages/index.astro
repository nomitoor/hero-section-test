---
import "../styles/global.css";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>The Atelier</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Inter:wght@300;400&display=swap"
			rel="stylesheet"
		/>

		<style>
			*, *::before, *::after {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			html,
			body {
				width: 100%;
				min-height: 100vh;
				background: #0f0d0a;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			/* ── Hero ── */
			.hero {
				position: relative;
				width: 100%;
				max-width: 100%;
				overflow: hidden;
				aspect-ratio: 16 / 9;
				font-family: 'Inter', sans-serif;
			}

			/* ── Full-bleed background image — zoomed so subject occupies ~40% of width ── */
			.hero__bg-img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: 60% center;
				display: block;
				z-index: 0;
			}

			/* ── Very subtle vignette to anchor the composition ── */
			.hero__vignette {
				position: absolute;
				inset: 0;
				z-index: 1;
				pointer-events: none;
				background: radial-gradient(
					ellipse 120% 110% at 50% 50%,
					transparent 55%,
					rgba(30, 18, 8, 0.18) 100%
				);
			}

			/* ── Text zone: sits over left empty-wall area ── */
			/* Image has ~42% empty wall on the left naturally */
			.hero__content {
				position: absolute;
				top: 0;
				left: 0;
				bottom: 0;
				width: 56%;
				padding-left: 7%;
				padding-right: 3%;
				display: flex;
				flex-direction: column;
				justify-content: center;
				/* 20-22% bottom offset — push text to upper-center of column */
				padding-bottom: 8%;
				z-index: 10;
			}

			/* ── H1: Cormorant Garamond Regular 64-72px / lh 1.08 ── */
			.hero__h1 {
				font-family: 'Cormorant Garamond', Georgia, serif;
				font-weight: 400;
				font-size: clamp(52px, 6.5vw, 96px);
				line-height: 1.08;
				letter-spacing: 0.04em;
				color: #1c1008;
				margin: 0 0 clamp(24px, 2.2vw, 36px) 0;
				text-rendering: optimizeLegibility;
			}

			/* ── Body: Inter 400 16-18px / lh 1.7 ── */
			.hero__p {
				font-family: 'Inter', sans-serif;
				font-weight: 400;
				font-size: clamp(15px, 1.35vw, 21px);
				line-height: 1.72;
				color: #2e1e0e;
				margin: 0;
				padding: 0;
			}
			.hero__p em {
				font-style: italic;
			}

			/* Between paragraphs 16-20px */
			.hero__p + .hero__p {
				margin-top: clamp(16px, 1.5vw, 24px);
			}

			/* Paragraph → keywords 32-36px */
			.hero__kws {
				display: flex;
				align-items: center;
				gap: 13px;
				margin-top: clamp(32px, 3vw, 48px);
			}
			.hero__rule {
				flex-shrink: 0;
				width: 28px;
				height: 1px;
				background: #1c1008;
			}
			.hero__kw {
				font-family: 'Inter', sans-serif;
				font-weight: 400;
				font-size: clamp(10px, 0.85vw, 13px);
				letter-spacing: 0.18em;
				color: #2e1e0e;
				white-space: nowrap;
			}

			/* Keywords → CTA 28-32px */
			.hero__cta {
				align-self: flex-start;
				margin-top: clamp(28px, 2.5vw, 40px);
				padding: 15px 32px;
				background: #8a7040;
				color: #fff;
				font-family: 'Inter', sans-serif;
				font-weight: 400;
				font-size: clamp(10px, 0.85vw, 13px);
				letter-spacing: 0.2em;
				text-transform: uppercase;
				text-decoration: none;
				display: inline-block;
				transition: background 0.2s ease, transform 0.15s ease;
			}
			.hero__cta:hover {
				background: #6e5830;
				transform: translateY(-1px);
			}

			/* ── Staggered fade-up on load ── */
			@keyframes fadeUp {
				from {
					opacity: 0;
					transform: translateY(22px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			@keyframes fadeIn {
				from {
					opacity: 0;
				}
				to {
					opacity: 1;
				}
			}

			.hero__bg-img {
				animation: fadeIn 1.4s ease both;
			}
			.hero__h1 {
				animation: fadeUp 0.9s cubic-bezier(0.22, 0.68, 0, 1.1) 0.3s both;
			}
			.hero__p:first-of-type {
				animation: fadeUp 0.8s ease 0.48s both;
			}
			.hero__p:last-of-type {
				animation: fadeUp 0.8s ease 0.58s both;
			}
			.hero__kws {
				animation: fadeUp 0.75s ease 0.7s both;
			}
			.hero__cta {
				animation: fadeUp 0.7s ease 0.84s both;
			}

			/* ── Responsive ── */
			@media (max-width: 900px) {
				.hero__content {
					width: 65%;
					padding-left: 5%;
				}
			}
			@media (max-width: 640px) {
				.hero {
					aspect-ratio: auto;
					min-height: 100svh;
				}
				.hero__bg-img {
					object-position: 68% center;
				}
				.hero__content {
					width: 100%;
					padding: 8% 6% 12%;
					justify-content: flex-end;
					background: linear-gradient(
						to top,
						rgba(196, 170, 138, 0.96) 0%,
						rgba(196, 170, 138, 0.82) 50%,
						transparent 100%
					);
				}
			}
		</style>
	</head>
	<body>
		<section class="hero" role="banner">
			<img
				class="hero__bg-img"
				src="/subject.png"
				alt="The Atelier — coaching studio interior"
				draggable="false"
			/>

			<div class="hero__vignette" aria-hidden="true"></div>

			<div class="hero__content">
				<h1 class="hero__h1">THE ATELIER</h1>

				<p class="hero__p">
					Begleitung, die dort ansetzt,<br />
					wo <em>Veränderung</em> tatsächlich entsteht.
				</p>

				<p class="hero__p">
					Die Arbeit beginnt nicht im Aussen.<br />
					Sondern im Inneren.
				</p>

				<div class="hero__kws">
					<span class="hero__rule" aria-hidden="true"></span>
					<span class="hero__kw"
						>STRUKTURIERT.&nbsp;&nbsp;RUHIG.&nbsp;&nbsp;GEFÜHRT.&nbsp;&nbsp;PRÄZISE.</span
					>
				</div>

				<a href="#" class="hero__cta">ERSTGESPRÄCH BUCHEN</a>
			</div>
		</section>
	</body>
</html>
